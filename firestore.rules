rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwnUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidEmail(email) {
      return email is string
        && email.size() <= 254
        && email.matches('^.+@.+\\..+$');
    }

    function isValidUserProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'providerIds',
          'createdAt',
          'updatedAt',
          'lastLoginAt'
        ])
        && request.resource.data.uid == uid
        && (request.resource.data.email == null || isValidEmail(request.resource.data.email))
        && (
          !('displayName' in request.resource.data)
          || request.resource.data.displayName == null
          || (
            request.resource.data.displayName is string
            && request.resource.data.displayName.size() >= 2
            && request.resource.data.displayName.size() <= 160
          )
        )
        && (
          !('photoURL' in request.resource.data)
          || request.resource.data.photoURL == null
          || (
            request.resource.data.photoURL is string
            && request.resource.data.photoURL.size() <= 2000
          )
        )
        && (
          !('providerIds' in request.resource.data)
          || (
            request.resource.data.providerIds is list
            && request.resource.data.providerIds.size() <= 10
          )
        )
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastLoginAt is timestamp;
    }

    function isValidSavedProduct(productId) {
      return request.resource.data.keys().hasOnly([
          'productId',
          'savedAt'
        ])
        && request.resource.data.productId == productId
        && request.resource.data.savedAt is timestamp;
    }

    function isPublicInquiryPayload() {
      return request.resource.data.keys().hasOnly([
          'name',
          'email',
          'message',
          'createdAt',
          'status',
          'source'
        ])
        && request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && isValidEmail(request.resource.data.email)
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 3000
        && request.resource.data.createdAt is timestamp
        && (!('status' in request.resource.data) || request.resource.data.status == 'Шинэ')
        && (!('source' in request.resource.data) || request.resource.data.source is string);
    }

    function isPublicCustomOrderPayload() {
      return request.resource.data.keys().hasOnly([
          'name',
          'email',
          'message',
          'productType',
          'materials',
          'stone',
          'createdAt',
          'status',
          'source'
        ])
        && request.resource.data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 120
        && isValidEmail(request.resource.data.email)
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 4000
        && (!('productType' in request.resource.data) || request.resource.data.productType is string)
        && (!('materials' in request.resource.data) || request.resource.data.materials is string)
        && (!('stone' in request.resource.data) || request.resource.data.stone is string)
        && request.resource.data.createdAt is timestamp
        && (!('status' in request.resource.data) || request.resource.data.status == 'Шинэ')
        && (!('source' in request.resource.data) || request.resource.data.source is string);
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /siteSettings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || isOwnUser(uid);
      allow create, update: if isAdmin() || (isOwnUser(uid) && isValidUserProfile(uid));
      allow delete: if isAdmin();

      match /savedProducts/{productId} {
        allow read: if isAdmin() || isOwnUser(uid);
        allow create, update: if isAdmin() || (isOwnUser(uid) && isValidSavedProduct(productId));
        allow delete: if isAdmin() || isOwnUser(uid);
      }
    }

    match /inquiries/{inquiryId} {
      allow create: if isPublicInquiryPayload();
      allow read, update, delete: if isAdmin();
    }

    match /customOrders/{orderId} {
      allow create: if isPublicCustomOrderPayload();
      allow read, update, delete: if isAdmin();
    }

    match /adminUsers/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
