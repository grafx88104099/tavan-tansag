rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAllowedAdminEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email == 'amardelgerekh@gmail.com';
    }

    function hasAdminRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isAdmin() {
      return isSignedIn()
        && (
          request.auth.token.admin == true
          || isAllowedAdminEmail()
          || hasAdminRole()
        );
    }

    function isOwnUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidEmail(email) {
      return email is string
        && email.size() <= 254
        && email.matches('^.+@.+\\..+$');
    }

    function isValidRole(role) {
      return role == 'customer' || role == 'admin';
    }

    function hasValidProviderIds(providerIds) {
      return providerIds is list && providerIds.size() <= 10;
    }

    function isValidUserProfile(uid) {
      return request.resource.data.keys().hasOnly([
          'uid',
          'email',
          'displayName',
          'photoURL',
          'providerIds',
          'role',
          'createdAt',
          'updatedAt',
          'lastLoginAt'
        ])
        && request.resource.data.uid == uid
        && isValidRole(request.resource.data.role)
        && (request.resource.data.email == null || isValidEmail(request.resource.data.email))
        && (
          !('displayName' in request.resource.data)
          || request.resource.data.displayName == null
          || (
            request.resource.data.displayName is string
            && request.resource.data.displayName.size() >= 2
            && request.resource.data.displayName.size() <= 160
          )
        )
        && (
          !('photoURL' in request.resource.data)
          || request.resource.data.photoURL == null
          || (
            request.resource.data.photoURL is string
            && request.resource.data.photoURL.size() <= 2000
          )
        )
        && (
          !('providerIds' in request.resource.data)
          || hasValidProviderIds(request.resource.data.providerIds)
        )
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && request.resource.data.lastLoginAt is timestamp;
    }

    function isOwnUserProfileCreate(uid) {
      return isOwnUser(uid)
        && isValidUserProfile(uid)
        && request.resource.data.role == 'customer';
    }

    function isOwnUserProfileUpdate(uid) {
      return isOwnUser(uid)
        && resource != null
        && isValidUserProfile(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function isValidSavedProduct(productId) {
      return request.resource.data.keys().hasOnly([
          'productId',
          'savedAt'
        ])
        && request.resource.data.productId == productId
        && request.resource.data.savedAt is timestamp;
    }

    function isValidProductCategory() {
      return request.resource.data.category == 'Snuff Bottle'
        || request.resource.data.category == 'Ring'
        || request.resource.data.category == 'Bracelet'
        || request.resource.data.category == 'Earrings'
        || request.resource.data.category == 'Necklace'
        || request.resource.data.category == 'Stone Jewelry';
    }

    function isValidProductStoneType() {
      return request.resource.data.stoneType == 'Turquoise'
        || request.resource.data.stoneType == 'Jade'
        || request.resource.data.stoneType == 'Coral'
        || request.resource.data.stoneType == 'Lapis Lazuli'
        || request.resource.data.stoneType == 'Agate'
        || request.resource.data.stoneType == 'None';
    }

    function isValidProductMaterial() {
      return request.resource.data.material == 'Silver'
        || request.resource.data.material == 'Gold'
        || request.resource.data.material == 'Bronze'
        || request.resource.data.material == 'Mixed';
    }

    function isValidProductPayload(productId) {
      return request.resource.data.keys().hasOnly([
          'name',
          'category',
          'stoneType',
          'material',
          'description',
          'size',
          'price',
          'images',
          'imagePaths',
          'coverImageUrl',
          'coverImagePath',
          'coverImageHint',
          'createdAt',
          'updatedAt'
        ])
        && productId.size() > 0
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 160
        && isValidProductCategory()
        && isValidProductStoneType()
        && isValidProductMaterial()
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 2
        && request.resource.data.description.size() <= 3000
        && request.resource.data.size is string
        && request.resource.data.size.size() >= 1
        && request.resource.data.size.size() <= 120
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && (
          !('images' in request.resource.data)
          || (
            request.resource.data.images is list
            && request.resource.data.images.size() <= 20
          )
        )
        && (
          !('imagePaths' in request.resource.data)
          || (
            request.resource.data.imagePaths is list
            && request.resource.data.imagePaths.size() <= 20
          )
        )
        && (
          !('coverImageUrl' in request.resource.data)
          || request.resource.data.coverImageUrl == null
          || (
            request.resource.data.coverImageUrl is string
            && request.resource.data.coverImageUrl.size() <= 2000
          )
        )
        && (
          !('coverImagePath' in request.resource.data)
          || request.resource.data.coverImagePath == null
          || (
            request.resource.data.coverImagePath is string
            && request.resource.data.coverImagePath.size() <= 300
          )
        )
        && (
          !('coverImageHint' in request.resource.data)
          || request.resource.data.coverImageHint == null
          || (
            request.resource.data.coverImageHint is string
            && request.resource.data.coverImageHint.size() <= 120
          )
        )
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function isValidHeritagePayload() {
      return request.resource.data.keys().hasOnly([
          'title',
          'videoUrl',
          'videoPath',
          'posterImageUrl',
          'updatedAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() >= 2
        && request.resource.data.title.size() <= 160
        && (
          request.resource.data.videoUrl == null
          || (
            request.resource.data.videoUrl is string
            && request.resource.data.videoUrl.size() <= 2000
          )
        )
        && (
          request.resource.data.videoPath == null
          || (
            request.resource.data.videoPath is string
            && request.resource.data.videoPath.size() <= 300
          )
        )
        && (
          request.resource.data.posterImageUrl == null
          || (
            request.resource.data.posterImageUrl is string
            && request.resource.data.posterImageUrl.size() <= 2000
          )
        )
        && request.resource.data.updatedAt is timestamp;
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidProductPayload(productId);
      allow delete: if isAdmin();
    }

    match /siteSettings/{documentId} {
      allow read: if true;
      allow create, update: if isAdmin() && documentId == 'heritage' && isValidHeritagePayload();
      allow delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || isOwnUser(uid);
      allow create: if (isAdmin() && isValidUserProfile(uid)) || isOwnUserProfileCreate(uid);
      allow update: if (isAdmin() && isValidUserProfile(uid)) || isOwnUserProfileUpdate(uid);
      allow delete: if isAdmin();

      match /savedProducts/{productId} {
        allow read: if isAdmin() || isOwnUser(uid);
        allow create, update: if isAdmin() || (isOwnUser(uid) && isValidSavedProduct(productId));
        allow delete: if isAdmin() || isOwnUser(uid);
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
